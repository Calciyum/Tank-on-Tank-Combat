                    pygame.draw.rect(screen, BLACK, rect, width=2)
                else:
                    pygame.draw.rect(screen, BLACK, rect, width=0)
                xpos += WIDTH/num_rows
            ypos += HEIGHT/num_cols

        #visual display of objects (players, shells, mines)
        for i in range(num_rows):
            xpos = 0
            for j in range(num_cols):
                if attack_grid[i][j] == 1:
                    pygame.draw.circle(screen, RED, (SQUARE_SIZE * j+1 + SQUARE_SIZE/2, SQUARE_SIZE * i+1 + SQUARE_SIZE/2), WIDTH/(num_rows * 2), width=0)
                elif attack_grid[i][j] == 2:
                    pygame.draw.circle(screen, BLUE, (SQUARE_SIZE * j+1 + SQUARE_SIZE/2, SQUARE_SIZE * i+1 + SQUARE_SIZE/2), WIDTH/(num_rows * 2), width=0)
                elif attack_grid[i][j] == 3:
                    pygame.draw.circle(screen, BLACK, (SQUARE_SIZE * j + SQUARE_SIZE/2, SQUARE_SIZE * i + SQUARE_SIZE/2), WIDTH/(num_rows * 4), width=0)
                else:
                    rect = pygame.Rect(xpos, ypos - HEIGHT/num_cols, WIDTH/num_rows, HEIGHT/num_cols)
                    pygame.draw.rect(screen, BLACK, rect, width=2)
                if Turn % 2 == 0:
                    current_team = 1
                else:
                    current_team = 2
                if mine_grid[i][j] == current_team:
                    if current_team == 1:
                        pygame.draw.circle(screen, RED, (SQUARE_SIZE * j + SQUARE_SIZE/2, SQUARE_SIZE * i + SQUARE_SIZE/2), WIDTH/(num_rows * 3), width=4)
                    else:
                        pygame.draw.circle(screen, BLUE, (SQUARE_SIZE * j + SQUARE_SIZE/2, SQUARE_SIZE * i + SQUARE_SIZE/2), WIDTH/(num_rows * 3), width=4)
                for m in mines:
                    if m.team == current_team and m.delay > 5:
                        if m.team == 1:
                            color = RED
                        else:
                            color = BLUE
                        pygame.draw.circle(screen, color, (SQUARE_SIZE * m.col + SQUARE_SIZE/2, SQUARE_SIZE * m.row + SQUARE_SIZE/2), WIDTH/(num_rows * 8), width=0)

    #game over display
    if game_over:
        if winner == 1:
            winner_text = "Red Tank Wins!"
            color = RED
        elif winner == 2:
            winner_text = "Blue Tank Wins!"
            color = BLUE
        else:
            winner_text = "It's a Draw!"
            color = WHITE
        text = font_Large.render(winner_text, True, color)
        screen.blit(text, (WIDTH//2 - text.get_width()//2, HEIGHT//2 - 50))
        cause_text = font_Small.render(f"Cause: {cause}", True, WHITE)
        screen.blit(cause_text, (WIDTH//2 - cause_text.get_width()//2, HEIGHT//2 + 10))
        restart_text = font_Small.render("Press Enter to Return to Title or ESC to Quit", True, WHITE)
        screen.blit(restart_text, (WIDTH//2 - restart_text.get_width()//2, HEIGHT//2 + 50))

    #run the fade
    if fading:
        fade_surface = pygame.Surface((WIDTH, HEIGHT))
        fade_surface.fill((0, 0, 0))
        if fade_direction == "out":
            fade += fade_speed
            if fade >= 255:
                fade = 255
                state = next_state
                fade_direction = "in"
        elif fade_direction == "in":
            fade -= fade_speed
            if fade <= 0:
                fade = 0
                fading = False
                fade_direction = None
        fade_surface.set_alpha(fade)
        screen.blit(fade_surface, (0, 0))

    pygame.display.flip()

