                        player2 = player(13, 12, 2)

                        #start fade
                        fading = True
                        fade_direction = "out"
                        fade = 0
                        next_state = "title"
                    elif event.key == pygame.K_ESCAPE:
                        running = False
                    continue

                #exit game
                if event.key == pygame.K_ESCAPE:
                    running = False

                #movement, movement, and more movement
                elif event.key == pygame.K_q:
                    if Turn % 2 == 0:
                        player1.move(-1, -1)
                    else:
                        player2.move(-1, -1)
                    Turn += 1
                elif event.key == pygame.K_w:
                    if Turn % 2 == 0:
                        player1.move(-1, 0)
                    else:
                        player2.move(-1, 0)
                    Turn += 1
                elif event.key == pygame.K_e:
                    if Turn % 2 == 0:
                        player1.move(-1, +1)
                    else:
                        player2.move(-1, +1)
                    Turn += 1
                elif event.key == pygame.K_a:
                    if Turn % 2 == 0:
                        player1.move(0, -1)
                    else:
                        player2.move(0, -1)
                    Turn += 1
                elif event.key == pygame.K_d:
                    if Turn % 2 == 0:
                        player1.move(0, +1)
                    else:
                        player2.move(0, +1)
                    Turn += 1
                elif event.key == pygame.K_z:
                    if Turn % 2 == 0:
                        player1.move(+1, -1)
                    else:
                        player2.move(+1, -1)
                    Turn += 1
                elif event.key == pygame.K_s:
                    if Turn % 2 == 0:
                        player1.move(+1, 0)
                    else:
                        player2.move(+1, 0)
                    Turn += 1
                elif event.key == pygame.K_c:
                    if Turn % 2 == 0:
                        player1.move(+1, +1)
                    else:
                        player2.move(+1, +1)
                    Turn += 1
                
                #mine button
                elif event.key == pygame.K_SPACE:
                    if Turn % 2 == 0:
                        m = mine(player1.row, player1.col, 0, 1)
                        mines.append(m)
                    else:
                        m = mine(player2.row, player2.col, 0, 2)
                        mines.append(m)
                    Turn += 1
                
                #shells x4 directions
                elif event.key == pygame.K_UP:
                    if Turn % 2 == 0:
                        s = shell(player1.row, player1.col, -1, 0, 1)
                        if s.active:
                            shells.append(s)
                    else:
                        s = shell(player2.row, player2.col, -1, 0, 2)
                        if s.active:
                            shells.append(s)
                    Turn += 1
                elif event.key == pygame.K_LEFT:
                    if Turn % 2 == 0:
                        s = shell(player1.row, player1.col, 0, -1, 1)
                        if s.active:
                            shells.append(s)
                    else:
                        s = shell(player2.row, player2.col, 0, -1, 2)
                        if s.active:
                            shells.append(s)
                    Turn += 1
                elif event.key == pygame.K_RIGHT:
                    if Turn % 2 == 0:
                        s = shell(player1.row, player1.col, 0, 1, 1)
                        if s.active:
                            shells.append(s)
                    else:
                        s = shell(player2.row, player2.col, 0, 1, 2)
                        if s.active:
                            shells.append(s)
                    Turn += 1
                elif event.key == pygame.K_DOWN:
                    if Turn % 2 == 0:
                        s = shell(player1.row, player1.col, +1, 0, 1)
                        if s.active:
                            shells.append(s)
                    else:
                        s = shell(player2.row, player2.col, +1, 0, 2)
                        if s.active:
                            shells.append(s)
                    Turn += 1

    #incrementation of offensive stuff
    if state == "game" and Turn != last_turn:
        if Turn % 2 == 0:
            current_team = 1
        else:
            current_team = 2
        new_shells = []
        for s in shells:
            if s.team == current_team:
                if s.move():
                    new_shells.append(s)
            else:
                new_shells.append(s)
        shells = new_shells
        for m in mines:
            if m.team == current_team:
                m.delay += 1
        last_turn = Turn

    #fill background for current state
    if state == "title":
        screen.fill(TITLE)
    elif state == "game":
        if Turn % 2 == 0:
            screen.fill(LIGHT_RED)
        else:
            screen.fill(LIGHT_BLUE)

        #visual display of game_grid
        xpos = 0
        ypos = 0
        for i in range(num_rows):
            xpos = 0
            for j in range(num_cols):
                rect = pygame.Rect(xpos, ypos, WIDTH/num_rows, HEIGHT/num_cols)
