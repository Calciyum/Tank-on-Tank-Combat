                    fade_direction = "out"
                    fade = 0
                    next_state = "game"
                elif event.key == pygame.K_ESCAPE:
                    running = False

            elif state == "game":
                if game_over:
                    if event.key == pygame.K_RETURN:
                        
                        #reset game variables just like starting from title
                        shells = []
                        mines = []
                        Turn = 0
                        last_turn = -1
                        game_over = False
                        winner = None

                        #clear grids
                        for i in range(num_rows):
                            for j in range(num_cols):
                                attack_grid[i][j] = 0
                                mine_grid[i][j] = 0

                        #reset players
