#class that represents the player
class player(pygame.sprite.Sprite):
    #intialization function
    def __init__(self, row, col, team):
        self.row = row
        self.col = col
        self.team = team

        attack_grid[self.row][self.col] = self.team
    
    #movement function
    def move(self, row_change, col_change):
        global game_over, winner, cause
        new_row = self.row + row_change
        new_col = self.col + col_change

        if 0 <= new_row < num_rows and 0 <= new_col < num_cols:
            #check for any obstruction
            if game_grid[new_row][new_col] == 0 and (attack_grid[new_row][new_col] == 0 or attack_grid[new_row][new_col] == 3):
                if attack_grid[new_row][new_col] == 3:
                    if self.team == 1:
                        winner = 2
                    else:
                        winner = 1
                    game_over = True
                    cause = "Shell"
                for s in shells:
                    if s.row == new_row and s.col == new_col:
                        shells.remove(s)
                        break
                
                #check your feet (for mines)
                for m in mines:
                    if m.row == new_row and m.col == new_col:
                        if m.delay > 5:
                            if self.team == 1:
                                winner = 2
                            else:
                                winner = 1
                        game_over = True
                        cause = "Mine"
                        break
                
                #bye bye old position, hello new position
                attack_grid[self.row][self.col] = 0
                self.row = new_row
                self.col = new_col
                attack_grid[self.row][self.col] = self.team

#class that represents the shells
class shell:
    def __init__(self, row, col, row_change, col_change, team):
        global game_over, winner, cause
        self.row_change = row_change
        self.col_change = col_change
        self.row = row + row_change
        self.col = col + col_change
        self.team = team
        self.active = True

        #checks to prevent shells from spawning in walls, first one checks bounds
        if not (0 <= self.row < num_rows and 0 <= self.col < num_cols):
            self.active = False
            return
        
        if game_grid[self.row][self.col] == 1:
            self.active = False
            return
        
        #checks for players on spawning
        if attack_grid[self.row][self.col] == 1:
            attack_grid[self.row][self.col] = 0
            game_over = True
            winner = 2
            cause = "Shell"
        
        if attack_grid[self.row][self.col] == 2:
            attack_grid[self.row][self.col] = 0
            game_over = True
            winner = 1
            cause = "Shell"
        
        attack_grid[self.row][self.col] = 3
    #function for shell traveling
    def move(self):
        global game_over, winner, cause
        
        new_row = self.row + self.row_change
        new_col = self.col + self.col_change

        #bye bye old shell (hermit crabs)
        attack_grid[self.row][self.col] = 0

        #check map bounds
        if not (0 <= new_row < num_rows and 0 <= new_col < num_cols):
            return False

        #check for walls
        if game_grid[new_row][new_col] == 1:
            return False
        
        #check for players
        if attack_grid[new_row][new_col] == 1:
            attack_grid[new_row][new_col] = 0
            game_over = True
            winner = 2
            cause = "Shell"
            return False
        
        if attack_grid[new_row][new_col] == 2:
            attack_grid[new_row][new_col] = 0
            game_over = True
            winner = 1
            cause = "Shell"
            return False

        self.row = new_row
        self.col = new_col
        attack_grid[self.row][self.col] = 3
        return True

